# Auto detect text files and perform LF normalization
* text=auto

*.sh text eol=lf
auto/* text eol=lf
*.hook.chroot text eol=lf
*.list.chroot text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.xml text eol=lf
*.desktop text eol=lf
*.dockitem text eol=lf
*.conf text eol=lf
*.ini text eol=lf
